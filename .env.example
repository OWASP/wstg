SYSREPTOR_URL=https://sysreptor.example.com
SYSREPTOR_TOKEN=replace-with-api-token

# Required when creating a new report/project.
SYSREPTOR_PROJECT_DESIGN=replace-with-project-design-id

# Optional: populate an existing report/project instead of creating a new one.
# SYSREPTOR_PROJECT_ID=replace-with-existing-project-id

# Optional defaults matching the previous Python importer.
# SYSREPTOR_LANGUAGE=de-DE
# SYSREPTOR_PLACEHOLDER_LANGUAGE=de-DE
# SYSREPTOR_ALLOW_DUPLICATES=false
# Fetches SysReptor templates with this tag and matches them by title.
# SYSREPTOR_TEMPLATE_TAG=web
# File overwritten with selected checklist findings that have no matching template title.
# SYSREPTOR_MISSING_TEMPLATES_FILE=sysreptor_missing_templates.md
# Creates TODO findings when a matched template ID is rejected by SysReptor.
# SYSREPTOR_FALLBACK_ON_TEMPLATE_ERROR=true
